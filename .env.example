# ─────────────────────────────────────────────────────────────────────────────
# Threadline — Environment Variables
# Copy this file to .env and fill in your values.
# Variables without a default are REQUIRED.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────────────────────
# Which extractor backend to use: openai | gemini | mock
# Falls back to "mock" automatically if the selected backend has no API key.
# The four demo fixtures (meeting_01..04) always use deterministic mock output,
# regardless of this setting, so the flagship demo stays reproducible.
EXTRACTOR_BACKEND=gemini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# GEMINI_API_KEY also enables real audio transcription on the backend pipeline.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Lyzr Studio (mandatory hackathon integration) ─────────────────────────────
# When BOTH are set, extraction for real (non-fixture) uploads is delegated to
# your Lyzr Studio agent; the structured result is still persisted to the local
# Neo4j/Qdrant stores. If Lyzr is unset or a call fails, the backend falls back
# automatically to in-process Gemini/ADK (or mock) — it never crashes.
LYZR_API_KEY=
LYZR_AGENT_ID=
# Optional overrides:
# LYZR_USER_ID=threadline@tesseract.ai
# LYZR_BASE_URL=https://agent-prod.studio.lyzr.ai/v3/inference/chat/

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Which graph backend to use: neo4j | memory
# Falls back to "memory" automatically if Neo4j is unreachable at startup.
GRAPH_BACKEND=neo4j

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=threadline_dev

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Which vector backend to use: qdrant | memory
# Falls back to "memory" automatically if Qdrant is unreachable at startup.
VECTOR_BACKEND=qdrant

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=threadline_facts

# ── Embeddings ────────────────────────────────────────────────────────────────
# Model used by InMemoryVectorStore. Must match the model pre-downloaded in Docker.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# CORS: comma-separated origins allowed by the backend.
# Add your Vercel frontend URL here for production.
# CORS_ORIGINS=http://localhost:5173,https://threadline.vercel.app
